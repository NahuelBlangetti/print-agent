# Copiado de .env.example y ajustado para desarrollo local.

APP_NAME=Print Agent
VERSION=1.0.0

HOST=127.0.0.1
PORT=58432

LOG_LEVEL=INFO

QUEUE_MAX_SIZE=100

# Origenes permitidos para llamar al agente desde el navegador (CORS).
# Ambas apps Laravel (system-manager-punto-manija y system-manager-ferreteria)
# corren en local en el mismo puerto (no simultaneamente).
CORS_ORIGINS=["http://localhost:8000"]

# Para una futura version con autenticacion por API Key:
# API_KEY=tu-api-key-secreta
