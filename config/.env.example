# Copiar este archivo a config/.env y ajustar valores segun el entorno.

APP_NAME=Print Agent
VERSION=1.0.0

HOST=127.0.0.1
PORT=58432

LOG_LEVEL=INFO

QUEUE_MAX_SIZE=100

# Origenes permitidos para llamar al agente desde el navegador (CORS).
# Debe ser el/los dominio(s) donde esta alojada la app Laravel.
# Sin esto, el navegador bloquea las llamadas hechas desde JS.
CORS_ORIGINS=["https://app.tuempresa.com"]

# Para una futura version con autenticacion por API Key:
# API_KEY=tu-api-key-secreta
